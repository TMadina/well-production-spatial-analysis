# Well Production Analysis

import pandas as pd
import matplotlib.pyplot as plt
import numpy as np

df=pd.read_csv('wells.csv')
df.head()

x = df['depth_m']
y = df['production']

# correlation
correlation = df['depth_m'].corr(df['production'])

# trend line
z = np.polyfit(x, y, 1)
p = np.poly1d(z)

# schedule
plt.scatter(x, y)
plt.plot(x, p(x))
plt.xlabel('Depth (m)')
plt.ylabel('Production')
plt.title(f'Depth vs Production (corr={correlation:.2f})')

plt.show()

## Conclusion

A positive correlation between depth and production was observed.  
This suggests that deeper wells tend to have higher production.
